{
  "name": "promptcanary",
  "version": "1.1.0",
  "description": "Test your LLM prompts like you test your code. Assertions, semantic similarity, and multi-provider testing for Vitest, Jest, and any test runner.",
  "author": {
    "name": "Vebjørn Nyvoll",
    "url": "https://github.com/VebjornNyvoll"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "promptcanary": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VebjornNyvoll/promptcanary.git"
  },
  "keywords": [
    "llm",
    "testing",
    "prompt-testing",
    "llm-testing",
    "vitest",
    "jest",
    "ai",
    "assertions",
    "semantic-similarity",
    "openai",
    "anthropic",
    "google",
    "gemini"
  ],
  "homepage": "https://github.com/VebjornNyvoll/promptcanary#readme",
  "bugs": {
    "url": "https://github.com/VebjornNyvoll/promptcanary/issues"
  },
  "files": [
    "dist",
    "examples",
    "examples/template.vitest.ts",
    "examples/template.jest.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsup",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run test && pnpm run lint"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.43.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "openai": "^6.25.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  }
}
